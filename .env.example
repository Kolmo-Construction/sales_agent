# LLM (Ollama — local, no API key needed)
LLM_PROVIDER=ollama
LLM_MODEL=gemma2:9b
LLM_FAST_MODEL=llama3.2:latest
OLLAMA_HOST=http://localhost:11434
# OUTLINES_GGUF_PATH=              # only needed when LLM_PROVIDER=outlines
#   Find path: ollama show gemma2:9b --modelfile | grep FROM

# Vector store
QDRANT_URL=http://localhost:6333   # local Docker, OR Qdrant Cloud URL (include :6333)
QDRANT_API_KEY=                    # leave blank for local Docker; required for Qdrant Cloud

# Embeddings (FastEmbed — local CPU, no API key)
DENSE_MODEL=BAAI/bge-small-en-v1.5
SPARSE_MODEL=prithivida/Splade_PP_en_v1

# Database — production (LangGraph checkpointing + user summaries)
POSTGRES_DSN=postgresql://user:pass@localhost:5432/sales_agent

# Database — internal feedback tooling (separate DB — do not mix with production)
# Setup: createdb sales_agent_feedback && psql sales_agent_feedback < db/schema.sql
FEEDBACK_POSTGRES_DSN=postgresql://user:pass@localhost:5432/sales_agent_feedback

# Observability — Langfuse (optional; pipeline works without it)
# Self-hosted:  docker compose --profile langfuse up -d  → LANGFUSE_HOST=http://localhost:3000
# Cloud:        get keys from langfuse.com/project → leave LANGFUSE_HOST unset
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000    # remove this line to use cloud.langfuse.com
