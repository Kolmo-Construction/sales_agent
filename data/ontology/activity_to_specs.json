{
  "_schema": {
    "version": "1.0",
    "description": "Maps activities to required product specs for catalog retrieval. Used by pipeline/translator.py.",
    "spec_operators": {
      "max": "Value must be at most N. Used for temperature ratings (lower = colder = warmer bag).",
      "min": "Value must be at least N. Used for waterproof ratings, capacity.",
      "value": "Value must equal exactly this string.",
      "any_of": "Value must be one of these options.",
      "preferred": "Prefer these values but do not hard-filter on them."
    },
    "modifier_format": "Keys are 'field=value' where field matches an ExtractedContext field name.",
    "modifier_merge": "Modifiers override base specs for matching keys. Multiple modifiers can apply simultaneously."
  },

  "backpacking": {
    "required_categories": ["sleep", "footwear", "layering", "camping"],
    "base": {
      "sleeping_bags": {
        "temperature_rating_f": {"max": 20},
        "insulation_type": {"preferred": ["down", "synthetic"]},
        "season_rating": {"value": "3-season"},
        "weight_oz": {"max": 48}
      },
      "hiking_boots": {
        "waterproofing": {"any_of": ["Gore-Tex", "H2No", "DWR only"]},
        "sole_stiffness": {"value": "moderate"}
      },
      "rain_shells": {
        "waterproofing": {"any_of": ["Gore-Tex", "H2No", "eVent"]},
        "waterproof_rating_mm": {"min": 10000}
      },
      "backpacks": {
        "extra": {"capacity_liters": {"min": 50}}
      }
    },
    "modifiers": {
      "experience_level=beginner": {
        "sleeping_bags": {"temperature_rating_f": {"max": 15}},
        "hiking_boots": {"sole_stiffness": {"value": "stiff"}}
      },
      "experience_level=expert": {
        "sleeping_bags": {"temperature_rating_f": {"max": 25}, "weight_oz": {"max": 32}}
      }
    },
    "notes": "Weight is critical. Prioritize lightweight options. Ultralight setups suit expert hikers."
  },

